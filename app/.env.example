# Copy this file to .env.local and fill in your real values from Firebase Console.
# .env.local is gitignored. These values are safe to expose in browser code
# (security comes from Firebase Realtime Database rules, not from secrecy of the keys).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Device id must match the ESP32's DEVICE_ID in secrets.h
VITE_DEVICE_ID=ESP32-VEH-01
